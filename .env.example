# ============================================================
# SyncRoom environment reference
# Copy values into your host's dashboard — do NOT commit a .env.
# ============================================================

# ---- Server (runtime — set on Render / Fly / your VPS) ----

# Listen port. Render injects PORT automatically; leave unset there.
PORT=3001

# Comma-separated origin allow-list for CORS/WebSocket handshakes.
# Exact origins and wildcard subdomains (https://*.vercel.app) are supported.
# Production example:
#   CLIENT_ORIGIN=https://syncroom.vercel.app,https://*.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ---- Client (BUILD-time — set in the Vercel dashboard) ----
# Vite inlines VITE_* variables at build time; changing them requires a
# redeploy, not a restart.

# The Socket.IO server URL (https:// — the socket upgrades to wss:// itself).
# Required for split deployments; omit when the server serves the SPA.
#   VITE_SERVER_URL=https://syncroom-server.onrender.com

# TURN relay for strict-NAT peers (~10-15% of connections fail without one).
# Free option: https://www.metered.ca/tools/openrelay/ (Open Relay).
#   VITE_TURN_URL=turn:standard.relay.metered.ca:443?transport=tcp
#   VITE_TURN_USERNAME=your-username
#   VITE_TURN_CREDENTIAL=your-credential
